# =============================================================================
# ORÓMA — Codeberg / Public Source Release .gitignore
# =============================================================================
# Project:        ORÓMA — Offline-Realtime-Organic-Memory-AI
# Purpose:        Keep the public Codeberg repository aligned with the public
#                 Zenodo/MIT source release while preventing accidental upload
#                 of live runtime data, SQLite databases, logs, caches, local
#                 machine state, secrets, backups, models, third-party build
#                 trees and internal/legacy Markdown documentation.
# Baseline:       Public release layout comparable to:
#                 /mnt/data/oroma_20260518_zenodo_public_release_mit.zip
# Live reference: Runtime tree comparable to:
#                 /mnt/data/oroma_20260519_203723_with_db.zip
# Safety model:   Conservative allow-list for Markdown. Most source code is
#                 allowed by default, but generated/runtime/private material is
#                 ignored. Markdown is ignored globally and then only the
#                 public Zenodo Markdown files are explicitly re-allowed.
# Usage:          Place as /opt/ai/oroma/.gitignore before git add .
# =============================================================================

# -----------------------------------------------------------------------------
# 1) Python caches, bytecode and test/build artefacts
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
build/
dist/
*.egg-info/
.eggs/

# -----------------------------------------------------------------------------
# 2) Virtual environments and local Python/runtime environments
# -----------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.python-version
pip-wheel-metadata/

# -----------------------------------------------------------------------------
# 3) Secrets, tokens, machine-local environment and credentials
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.csr
*.p12
*.pfx
*.secret
*.secrets
secrets/
private/

# -----------------------------------------------------------------------------
# 4) ORÓMA SQLite databases, WAL/SHM sidecars, DB locks and live memory stores
# -----------------------------------------------------------------------------
data/*.db
data/*.db-*
data/*.sqlite
data/*.sqlite3
*.db
*.db-*
*.sqlite
*.sqlite3
*.sqlite-journal
*.db-journal
*.lock
.oroma_db_write.lock
data/.oroma_db_write.lock

# -----------------------------------------------------------------------------
# 5) ORÓMA runtime data/state generated by the live instance
# -----------------------------------------------------------------------------
data/
state/
log/
logs/
uploads/
exports_out/
archives/
objectgraph_report.json
hailort.log
*.log
*.out
*.err
*.pid
*.sock
*.tmp
*.temp
*.bak
*.old
*.orig
*.rej

# -----------------------------------------------------------------------------
# 6) Runtime snapshots, media captures and local diagnostic files
# -----------------------------------------------------------------------------
*.jpg
*.jpeg
*.png
*.webp
*.gif
*.wav
*.mp3
*.flac
*.ogg
*.mp4
*.mkv
*.avi
*.mov
*.csv
*.jsonl
*.trace
*.pcap
*.pcapng

# Intentionally public metadata/test JSON outside runtime folders can remain.
!docs/**/*.json
!tests/**/*.json

# -----------------------------------------------------------------------------
# 7) Device, audio, video, Hailo, GStreamer and desktop/user caches
# -----------------------------------------------------------------------------
.cache/
.config/
.local/
.hailo/
gstshark_*/
.cache*/
mesa_shader_cache*/
gstreamer-1.0/
pulse/
wireplumber/

# -----------------------------------------------------------------------------
# 8) Large external dependencies, local model stores and compiled third-party
#    trees. Public releases should document how to fetch/build these instead of
#    committing local build output.
# -----------------------------------------------------------------------------
models/
third_party/
*.gguf
*.ggml
*.onnx
*.tflite
*.hef
*.pt
*.pth
*.safetensors
*.bin
*.so
*.so.*
*.a
*.o
*.obj
*.dll
*.dylib
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
compile_commands.json
CTestTestfile.cmake
DartConfiguration.tcl
Testing/
Makefile

# -----------------------------------------------------------------------------
# 9) Backup archives and package artefacts. Source should be committed as files;
#    release ZIP/TAR artefacts belong to Codeberg Releases or Zenodo, not git.
# -----------------------------------------------------------------------------
*.zip
*.tar
*.tar.gz
*.tgz
*.7z
*.rar
*.xz
*.gz
*.bz2
*.zst

# -----------------------------------------------------------------------------
# 10) Live-only root files currently not present in the Zenodo public source
#     package. These are excluded to keep Codeberg aligned with the public ZIP.
# -----------------------------------------------------------------------------
/To
/rollback_deploy.sh
/setup_os.sh
/setup_systemwide_oroma.sh
/test.wav
/objectgraph_report.json

# -----------------------------------------------------------------------------
# 11) OS/editor noise
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# 12) Markdown publication gate
# -----------------------------------------------------------------------------
# Default: do not publish arbitrary Markdown from the live system. The live tree
# contains many internal, old, duplicated or working Markdown files under docs/.
# Only the exact Markdown files already present in the public Zenodo/MIT release
# are re-enabled below.
*.md

