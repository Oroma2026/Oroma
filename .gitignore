# Hard blocks that must win even if future negation rules are added above.
# These patterns are intentionally at the end because the last matching rule wins.
docs/history/
docs/history/**
docs/current.md
docs/scientific_paper.md
docs/snaps_todo.md
docs/OROMA_PATCH_GATE.md
docs/OROMA_PATCH_GATE_*.md
docs/OROMA_REPLAY_UNIVERSAL.md
docs/OROMA_REPLAY_UNIVERSAL_*.md
docs/oroma_persistent_journal_und_fehleranalyse.md
docs/oroma_nas_mount_und_manuelles_backup.md
docs/Core-Review-Findings_PTZ_AudioReflex.md
docs/CHESS2_VS_CHESS3_MATCHUP_FAZIT.md
docs/FINAL_CHESS2_STATUS_*.md
docs/backup_oroma_with_db_summary.md
docs/OROMA_PTZ_Reflex_Integration_Spec.md

# -----------------------------------------------------------------------------
# 13) Preserve intentionally public non-Markdown root marker files
# -----------------------------------------------------------------------------
!ZENODO_PACKAGE_MANIFEST.txt
!LICENSE


# -----------------------------------------------------------------------------
# 14) Final hard blocks for local runtime marker and accidental Python backup copies
# -----------------------------------------------------------------------------
# These rules MUST remain after all negation rules. Do not add later !-rules for them.
.use_orchestrator
*.py-[0-9]*

# -----------------------------------------------------------------------------
# 15) Final public-release cleanup: local audit artifacts / patch leftovers
# -----------------------------------------------------------------------------
tree.txt
*.diff
*.patch
ui/static/chart.min.js.md

# =============================================================================
# End of ORÓMA public Codeberg .gitignore
# =============================================================================
