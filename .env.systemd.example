# =============================================================================
# ORÓMA Project / ORÓMA Projekt
# File / Datei: .env.systemd.example
#
# EN:
#   Public example file for service-level defaults in systemd deployments.
#
# DE:
#   Öffentliche Beispiel-Datei für dienstnahe Standardwerte in systemd-Deployments.
#
# Notes / Hinweise:
# - Copy this file to `.env.systemd` and adapt as needed.
# - Diese Datei nach `.env.systemd` kopieren und bei Bedarf anpassen.
# - `.env.systemd` is usually loaded before `.env`.
# - `.env.systemd` wird typischerweise vor `.env` geladen.
# =============================================================================

# -----------------------------------------------------------------------------
# Base path / Basispfad
# -----------------------------------------------------------------------------
OROMA_BASE=/opt/ai/oroma

# -----------------------------------------------------------------------------
# Python / Service behavior / Python / Service-Verhalten
# -----------------------------------------------------------------------------
PYTHONUNBUFFERED=1

# -----------------------------------------------------------------------------
# Flask / UI
# -----------------------------------------------------------------------------
FLASK_RUN_HOST=0.0.0.0
FLASK_RUN_PORT=8080

# -----------------------------------------------------------------------------
# Core runtime defaults / Core-Runtime-Defaults
# -----------------------------------------------------------------------------
OROMA_DBW_ENABLE=1
OROMA_AGENT_ENABLED=1
OROMA_REPLAY_LEARN=1
OROMA_AV_SNAPS=1

# -----------------------------------------------------------------------------
# Circadian / Dream defaults / Zirkadian / Dream-Defaults
# -----------------------------------------------------------------------------
OROMA_LIGHT_SOURCE=camera
OROMA_NIGHTMODE_LIGHT_THRESHOLD=25
OROMA_NIGHTMODE_DELAY_MINUTES=30

# -----------------------------------------------------------------------------
# Audio defaults / Audio-Defaults
# -----------------------------------------------------------------------------
OROMA_AUDIO_ENABLE=true

# -----------------------------------------------------------------------------
# Orchestrator / runtime mode / Orchestrator / Runtime-Modus
# -----------------------------------------------------------------------------
OROMA_ORCH_ENABLE=1

# -----------------------------------------------------------------------------
# Logging / diagnostics / Logging / Diagnostik
# -----------------------------------------------------------------------------
# EN: Keep public defaults generic.
# DE: Öffentliche Defaults möglichst generisch halten.
