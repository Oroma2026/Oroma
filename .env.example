# =============================================================================
# ORÓMA Project / ORÓMA Projekt
# File / Datei: .env.example
#
# EN:
#   Public example for instance-local overrides.
#   Copy this file to `.env` and adapt it for the local machine.
#
# DE:
#   Öffentliche Beispiel-Datei für instanzlokale Overrides.
#   Diese Datei nach `.env` kopieren und lokal anpassen.
#
# Notes / Hinweise:
# - Do NOT commit real secrets or real tokens.
# - Keine echten Secrets oder Tokens committen.
# - Values in `.env` may override `.env.systemd`.
# - Werte in `.env` können `.env.systemd` überschreiben.
# =============================================================================

# -----------------------------------------------------------------------------
# Base path / Basispfad
# -----------------------------------------------------------------------------
OROMA_BASE=/opt/ai/oroma

# -----------------------------------------------------------------------------
# UI / Access / Zugriff
# -----------------------------------------------------------------------------
# EN: Require UI token? 1=yes, 0=no
# DE: UI-Token erzwingen? 1=ja, 0=nein
OROMA_REQUIRE_TOKEN=0

# EN: Replace with a real local token if needed.
# DE: Falls nötig, lokal durch ein echtes Token ersetzen.
OROMA_UI_TOKEN=CHANGE_ME_UI_TOKEN

# -----------------------------------------------------------------------------
# Models / Storage / Modelle / Speicher
# -----------------------------------------------------------------------------
OROMA_MODELS_DIR=/opt/ai/oroma/models

# -----------------------------------------------------------------------------
# Light / Circadian / Licht / Zirkadian
# -----------------------------------------------------------------------------
# EN: Typical live value is "camera".
# DE: Typischer Live-Wert ist "camera".
OROMA_LIGHT_SOURCE=camera

# -----------------------------------------------------------------------------
# Camera examples / Kamera-Beispiele
# -----------------------------------------------------------------------------
# EN: Replace these with local device paths if needed.
# DE: Falls nötig, lokal durch echte Gerätepfade ersetzen.
# OROMA_CAMERA_DEVICE=/dev/video0
# OROMA_CAMERA_BY_ID=/dev/v4l/by-id/CHANGE_ME_CAMERA

# -----------------------------------------------------------------------------
# PTZ examples / PTZ-Beispiele
# -----------------------------------------------------------------------------
# OROMA_PTZ_DEVICE=/dev/ttyUSB0

# -----------------------------------------------------------------------------
# Optional runtime toggles / Optionale Runtime-Schalter
# -----------------------------------------------------------------------------
OROMA_DBW_ENABLE=1
OROMA_AGENT_ENABLED=1
OROMA_REPLAY_LEARN=1
OROMA_REPLAY_POLICY_UPSERT_ENABLE=0
OROMA_REPLAY_POLICY_CONFIRM=
OROMA_REPLAY_POLICY_NS_ALLOWLIST=replay
OROMA_REPLAY_POLICY_ALLOW_GENERIC_ACTION=0
OROMA_REPLAY_POLICY_DBW_TIMEOUT_MS=5000
OROMA_REPLAY_DBW_PING_TIMEOUT_MS=300
OROMA_REPLAY_DBW_PING_CACHE_SEC=5.0

# -----------------------------------------------------------------------------
# Local-only note / Hinweis nur lokal
# -----------------------------------------------------------------------------
# EN: Keep this file instance-local.
# DE: Diese Datei instanzlokal halten.

# -----------------------------------------------------------------------------
# Dream→Policy Auto-Mini-Write · Default-EIN-ENV-Gate
# -----------------------------------------------------------------------------
# Ziel:
#   Der Orchestrator darf die validierte Auto-Phase regelmäßig starten. Die
#   Phase bleibt trotzdem intern hart gegatet: DBWriter-only, Ledger-Pflicht,
#   Direct-Step-Credit-only, Daily-Cap, Cooldown und Confirm-Token.
#
# Abschalten:
#   OROMA_ORCH_ENABLE_DREAM_AUTO_MINI_WRITE=0
#
# Produktiver Startwert:
#   Maximal 1 Write pro Lauf, maximal 2 Writes pro Tag, mindestens 1h Abstand.
OROMA_ORCH_ENABLE_DREAM_AUTO_MINI_WRITE=1
OROMA_ORCH_INT_DREAM_AUTO_MINI_WRITE=3600
OROMA_ORCH_TIMEOUT_DREAM_AUTO_MINI_WRITE=120
OROMA_ORCH_DREAM_AUTO_MINI_WRITE_NAMESPACE=game:snake3d
OROMA_ORCH_DREAM_AUTO_MINI_WRITE_STATE_SCHEMA_PREFIX=snake3d:pro_v1
OROMA_ORCH_DREAM_AUTO_MINI_WRITE_LIMIT=20
OROMA_ORCH_DREAM_AUTO_MINI_WRITE_MAX=1
OROMA_ORCH_DREAM_AUTO_MINI_WRITE_DAILY_CAP=2
OROMA_ORCH_DREAM_AUTO_MINI_WRITE_COOLDOWN_S=3600
OROMA_ORCH_DREAM_AUTO_MINI_WRITE_MIN_DIRECT_EVIDENCE=3
OROMA_ORCH_DREAM_AUTO_MINI_WRITE_MIN_ABS_DELTA=0.0001
OROMA_ORCH_DREAM_AUTO_MINI_WRITE_CONFIRM=AUTO_DIRECT_STEP_CREDIT_ONLY

# -----------------------------------------------------------------------------
# Gap-Miner · Orchestrator-bounded DBWriter mode
# -----------------------------------------------------------------------------
# Ziel:
#   Proaktives Knowledge-Gap-Mining bleibt aktivierbar, darf aber die serielle
#   Orchestrator-Pipeline nicht mehr durch grosse Scans oder viele Einzelwrites
#   blockieren. Der Orchestrator startet gap_miner.py mit DBWriter-only,
#   Laufzeitbudget und Insert-Budget.
OROMA_ORCH_ENABLE_GAP_MINER=1
OROMA_ORCH_INT_GAP_MINER=600
OROMA_ORCH_TIMEOUT_GAP_MINER=90
OROMA_ORCH_GAP_MINER_MAX_RUNTIME_S=45
OROMA_ORCH_GAP_MINER_LIMIT_PER_KIND=50
OROMA_ORCH_GAP_MINER_MAX_INSERTS_PER_RUN=50
OROMA_ORCH_GAP_MINER_HU_ROW_SCAN_LIMIT=600
OROMA_ORCH_GAP_MINER_LE_ROW_SCAN_LIMIT=600
OROMA_ORCH_GAP_MINER_LC_ROW_SCAN_LIMIT=150
OROMA_GAP_MINER_REQUIRE_DBWRITER=1
# Gap-Miner Nacht-Sweep: arbeitet Rückstände nachts in bounded Cursor-Slices ab.
# Tagbetrieb bleibt kurz, Nachtbetrieb darf länger laufen, aber weiterhin DBWriter-only.
OROMA_ORCH_ENABLE_GAP_MINER_NIGHT=1
OROMA_ORCH_GAP_MINER_NIGHT_AT=02:35
OROMA_ORCH_TIMEOUT_GAP_MINER_NIGHT=3600
OROMA_ORCH_GAP_MINER_NIGHT_MAX_RUNTIME_S=3000
OROMA_ORCH_GAP_MINER_NIGHT_LIMIT_PER_KIND=500
OROMA_ORCH_GAP_MINER_NIGHT_MAX_INSERTS_PER_RUN=1000
OROMA_ORCH_GAP_MINER_NIGHT_SWEEP_PASSES=60
OROMA_ORCH_GAP_MINER_NIGHT_HU_ROW_SCAN_LIMIT=3000
OROMA_ORCH_GAP_MINER_NIGHT_LE_ROW_SCAN_LIMIT=3000
OROMA_ORCH_GAP_MINER_NIGHT_LC_ROW_SCAN_LIMIT=3000
OROMA_ORCH_GAP_MINER_NIGHT_SLICE_RUNTIME_S=120

# Gap-Learning-Bridge Dry-Run: macht knowledge_gaps als Lernfokus nutzbar,
# ohne DB-Writes, ohne policy_rules-Writes und ohne Runner-/Dream-Aktivierung.
OROMA_ORCH_ENABLE_GAP_LEARNING_BRIDGE=1
OROMA_ORCH_INT_GAP_LEARNING_BRIDGE=1800
OROMA_ORCH_TIMEOUT_GAP_LEARNING_BRIDGE=45
OROMA_ORCH_GAP_LEARNING_BRIDGE_MAX_RUNTIME_S=30
OROMA_ORCH_GAP_LEARNING_BRIDGE_LIMIT_GAPS=500
OROMA_ORCH_GAP_LEARNING_BRIDGE_TOPK=25
OROMA_GAP_LEARNING_LOOKBACK_SEC=604800
OROMA_GAP_LEARNING_LIMIT_GAPS=500
OROMA_GAP_LEARNING_TOPK=25
OROMA_GAP_LEARNING_MIN_CONFIDENCE=0.0
OROMA_GAP_LEARNING_NAMESPACE_ALLOWLIST=game:*
OROMA_GAP_LEARNING_COVERED_MIN_N=5
OROMA_GAP_LEARNING_UNCERTAINTY_EPS=0.05
OROMA_GAP_LEARNING_MAX_RUNTIME_S=30
OROMA_GAP_LEARNING_STATE_PATH=/opt/ai/oroma/data/state/gap_learning_focus.json

# Gap-Focus Consumer Read-Only: macht gap_learning_focus.json fuer spaetere
# Explore-/Replay-/Dream-/Runner-Verbraucher sichtbar, startet aber nichts.
OROMA_ORCH_ENABLE_GAP_FOCUS_CONSUMER=1
OROMA_ORCH_INT_GAP_FOCUS_CONSUMER=1800
OROMA_ORCH_TIMEOUT_GAP_FOCUS_CONSUMER=20
OROMA_ORCH_GAP_FOCUS_CONSUMER_TOPK=10
OROMA_ORCH_GAP_FOCUS_CONSUMER_MAX_AGE_SEC=7200
OROMA_GAP_FOCUS_CONSUMER_TARGETS=explore,replay,dream,runner_priority
OROMA_GAP_FOCUS_CONSUMER_TOPK=10
OROMA_GAP_FOCUS_CONSUMER_MAX_AGE_SEC=7200
OROMA_GAP_FOCUS_CONSUMER_ALLOW_STALE=0
OROMA_GAP_FOCUS_CONSUMER_NAMESPACE_ALLOWLIST=game:*
OROMA_GAP_FOCUS_CONSUMER_STATE_PATH=/opt/ai/oroma/data/state/gap_focus_consumer.json

# Gap-Focus Shadow Plan Read-Only: macht aus gap_focus_consumer.json einen
# auditierbaren Anschlussplan fuer Replay/Dream/Explore/Runner, startet aber nichts.
OROMA_ORCH_ENABLE_GAP_FOCUS_SHADOW_PLAN=1
OROMA_ORCH_INT_GAP_FOCUS_SHADOW_PLAN=1800
OROMA_ORCH_TIMEOUT_GAP_FOCUS_SHADOW_PLAN=20
OROMA_ORCH_GAP_FOCUS_SHADOW_PLAN_TOPK=10
OROMA_ORCH_GAP_FOCUS_SHADOW_PLAN_MAX_AGE_SEC=7200
OROMA_GAP_FOCUS_SHADOW_PLAN_TARGETS=explore,replay,dream,runner_priority
OROMA_GAP_FOCUS_SHADOW_PLAN_TOPK=10
OROMA_GAP_FOCUS_SHADOW_PLAN_MAX_AGE_SEC=7200
OROMA_GAP_FOCUS_SHADOW_PLAN_ALLOW_STALE=0
OROMA_GAP_FOCUS_SHADOW_PLAN_SOURCE_PATH=/opt/ai/oroma/data/state/gap_focus_consumer.json
OROMA_GAP_FOCUS_SHADOW_PLAN_STATE_PATH=/opt/ai/oroma/data/state/gap_focus_shadow_plan.json

# Gap Evidence Queue Writer: erster sicherer DBWriter-only Write aus der Gap-Kette.
# Schreibt deduplizierte Review-/Evidence-Requests in gap_focus_evidence_queue,
# aber niemals policy_rules und startet keine Runner-/Replay-/Dream-Jobs.
OROMA_ORCH_ENABLE_GAP_EVIDENCE_QUEUE=1
OROMA_ORCH_INT_GAP_EVIDENCE_QUEUE=1800
OROMA_ORCH_TIMEOUT_GAP_EVIDENCE_QUEUE=30
OROMA_ORCH_GAP_EVIDENCE_QUEUE_TOPK=10
OROMA_ORCH_GAP_EVIDENCE_QUEUE_MAX_AGE_SEC=7200
OROMA_GAP_EVIDENCE_QUEUE_WRITE_ENABLE=1
OROMA_GAP_EVIDENCE_QUEUE_CONFIRM_REQUIRED=GAP_EVIDENCE_QUEUE_WRITE_REVIEWED
OROMA_GAP_EVIDENCE_QUEUE_CONFIRM=GAP_EVIDENCE_QUEUE_WRITE_REVIEWED
OROMA_GAP_EVIDENCE_QUEUE_TARGETS=explore,replay,dream,runner_priority
OROMA_GAP_EVIDENCE_QUEUE_TOPK=10
OROMA_GAP_EVIDENCE_QUEUE_MAX_AGE_SEC=7200
OROMA_GAP_EVIDENCE_QUEUE_ALLOW_STALE=0
OROMA_GAP_EVIDENCE_QUEUE_SOURCE_PATH=/opt/ai/oroma/data/state/gap_focus_shadow_plan.json
OROMA_GAP_EVIDENCE_QUEUE_STATE_PATH=/opt/ai/oroma/data/state/gap_evidence_queue_writer.json
OROMA_GAP_EVIDENCE_QUEUE_DBW_TIMEOUT_MS=15000
OROMA_GAP_EVIDENCE_QUEUE_DBW_PING_TIMEOUT_MS=500

# Gap Evidence Queue Review Dry-Run (read-only; keine DB-/Policy-Writes, keine Starts)
OROMA_ORCH_ENABLE_GAP_EVIDENCE_REVIEW=1
OROMA_ORCH_INT_GAP_EVIDENCE_REVIEW=1800
OROMA_ORCH_TIMEOUT_GAP_EVIDENCE_REVIEW=20
OROMA_ORCH_GAP_EVIDENCE_REVIEW_LIMIT=200
OROMA_ORCH_GAP_EVIDENCE_REVIEW_TOPK=10
OROMA_GAP_EVIDENCE_REVIEW_TARGETS=explore,replay,dream,runner_priority
OROMA_GAP_EVIDENCE_REVIEW_STATUSES=queued
OROMA_GAP_EVIDENCE_REVIEW_LIMIT=200
OROMA_GAP_EVIDENCE_REVIEW_TOPK=10
OROMA_GAP_EVIDENCE_REVIEW_MIN_SCORE=0.0
OROMA_GAP_EVIDENCE_REVIEW_REQUIRE_POLICY_RULE=1
OROMA_GAP_EVIDENCE_REVIEW_COVERED_MIN_N=5
OROMA_GAP_EVIDENCE_REVIEW_UNCERTAINTY_EPS=0.05
OROMA_GAP_EVIDENCE_REVIEW_STATE_PATH=/opt/ai/oroma/data/state/gap_evidence_review.json
# Gap Evidence Execution/Validation Dry-Run (read-only; keine DB-/Policy-Writes, keine Starts)
OROMA_ORCH_ENABLE_GAP_EVIDENCE_VALIDATION=1
OROMA_ORCH_INT_GAP_EVIDENCE_VALIDATION=1800
OROMA_ORCH_TIMEOUT_GAP_EVIDENCE_VALIDATION=20
OROMA_ORCH_GAP_EVIDENCE_VALIDATION_LIMIT=200
OROMA_ORCH_GAP_EVIDENCE_VALIDATION_TOPK=10
OROMA_ORCH_GAP_EVIDENCE_VALIDATION_MAX_AGE_SEC=7200
OROMA_GAP_EVIDENCE_VALIDATION_BUCKETS=ready_for_replay_review,ready_for_dream_review,runner_priority_hint,explore_plan_candidate
OROMA_GAP_EVIDENCE_VALIDATION_LIMIT=200
OROMA_GAP_EVIDENCE_VALIDATION_TOPK=10
OROMA_GAP_EVIDENCE_VALIDATION_MAX_AGE_SEC=7200
OROMA_GAP_EVIDENCE_VALIDATION_ALLOW_STALE=0
OROMA_GAP_EVIDENCE_VALIDATION_MIN_SCORE=0.0
OROMA_GAP_EVIDENCE_VALIDATION_MIN_RULE_COUNT=1
OROMA_GAP_EVIDENCE_VALIDATION_MIN_TOTAL_N=1
OROMA_GAP_EVIDENCE_VALIDATION_SOURCE_PATH=/opt/ai/oroma/data/state/gap_evidence_review.json
OROMA_GAP_EVIDENCE_VALIDATION_STATE_PATH=/opt/ai/oroma/data/state/gap_evidence_validation.json

# Gap Policy Promotion Queue (DBWriter-only, no policy_rules write)
OROMA_ORCH_ENABLE_GAP_POLICY_PROMOTION=1
OROMA_ORCH_INT_GAP_POLICY_PROMOTION=1800
OROMA_ORCH_TIMEOUT_GAP_POLICY_PROMOTION=30
OROMA_ORCH_GAP_POLICY_PROMOTION_LIMIT=200
OROMA_ORCH_GAP_POLICY_PROMOTION_TOPK=10
OROMA_ORCH_GAP_POLICY_PROMOTION_MAX_AGE_SEC=7200
OROMA_GAP_POLICY_PROMOTION_WRITE_ENABLE=1
OROMA_GAP_POLICY_PROMOTION_CONFIRM_REQUIRED=GAP_POLICY_PROMOTION_REVIEWED
OROMA_GAP_POLICY_PROMOTION_CONFIRM=GAP_POLICY_PROMOTION_REVIEWED
OROMA_GAP_POLICY_PROMOTION_BUCKETS=validated_replay_execution_candidate,validated_dream_execution_candidate,validated_runner_priority_hint,validated_explore_candidate
OROMA_GAP_POLICY_PROMOTION_LIMIT=200
OROMA_GAP_POLICY_PROMOTION_TOPK=10
OROMA_GAP_POLICY_PROMOTION_MAX_AGE_SEC=7200
OROMA_GAP_POLICY_PROMOTION_ALLOW_STALE=0
OROMA_GAP_POLICY_PROMOTION_MIN_SCORE=0.0
OROMA_GAP_POLICY_PROMOTION_SOURCE_PATH=/opt/ai/oroma/data/state/gap_evidence_validation.json
OROMA_GAP_POLICY_PROMOTION_STATE_PATH=/opt/ai/oroma/data/state/gap_policy_promotion_queue_writer.json
OROMA_GAP_POLICY_PROMOTION_DBW_TIMEOUT_MS=15000
OROMA_GAP_POLICY_PROMOTION_DBW_PING_TIMEOUT_MS=500



# TTS Headless-Schutz
# - DeviceHub bleibt bevorzugter Ausgabeweg.
# - Kein direkter pyttsx3/espeak-Fallback ohne explizite Freigabe, damit
#   headless/systemd-Betrieb keine PortAudio/ALSA-Fehlerfluten erzeugt.
OROMA_TTS_DIRECT_PLAYBACK_ENABLE=false
OROMA_TTS_HUB_OUTPUT_PRECHECK=true
OROMA_TTS_NO_OUTPUT_CACHE_SEC=900
OROMA_TTS_SKIP_LOG_INTERVAL_SEC=900

# Gap Policy Mini-Write Gate · fail-closed · DBWriter-only · Ledger
OROMA_ORCH_ENABLE_GAP_POLICY_MINI_WRITE=1
OROMA_ORCH_INT_GAP_POLICY_MINI_WRITE=1800
OROMA_ORCH_TIMEOUT_GAP_POLICY_MINI_WRITE=20
OROMA_ORCH_GAP_POLICY_MINI_WRITE_LIMIT=50
OROMA_ORCH_GAP_POLICY_MINI_WRITE_TOPK=10
OROMA_ORCH_GAP_POLICY_MINI_WRITE_MAX_WRITES=1
OROMA_GAP_POLICY_MINI_WRITE_ENABLE=0
OROMA_GAP_POLICY_MINI_WRITE_CONFIRM_REQUIRED=GAP_POLICY_MINI_WRITE_REVIEWED
OROMA_GAP_POLICY_MINI_WRITE_CONFIRM=
OROMA_GAP_POLICY_MINI_WRITE_LEDGER_ENABLE=1
OROMA_GAP_POLICY_MINI_WRITE_RECORD_BLOCKED=1
OROMA_GAP_POLICY_MINI_WRITE_REQUIRE_EVIDENCE_OUTCOME=1
OROMA_GAP_POLICY_MINI_WRITE_ALLOW_DRAW_OUTCOME=0
OROMA_GAP_POLICY_MINI_WRITE_NAMESPACE_ALLOWLIST=game:*
OROMA_GAP_POLICY_MINI_WRITE_STATE_SCHEMA_ALLOWLIST=
OROMA_GAP_POLICY_MINI_WRITE_BUCKETS=promotion_candidate_replay,promotion_candidate_dream
OROMA_GAP_POLICY_MINI_WRITE_MIN_SCORE=0.0
OROMA_GAP_POLICY_MINI_WRITE_SOURCE=outcome_queue
OROMA_GAP_POLICY_MINI_WRITE_ALLOW_PROMOTION_META_FALLBACK=0
OROMA_GAP_POLICY_MINI_WRITE_MIN_CONFIDENCE=0.50
OROMA_GAP_POLICY_MINI_WRITE_OUTCOME_MAX_AGE_SEC=7200
OROMA_GAP_POLICY_MINI_WRITE_ALLOW_STALE_OUTCOME=0
OROMA_GAP_POLICY_MINI_WRITE_LIMIT=50
OROMA_GAP_POLICY_MINI_WRITE_TOPK=10
OROMA_GAP_POLICY_MINI_WRITE_MAX_WRITES_PER_RUN=1
OROMA_GAP_POLICY_MINI_WRITE_STATE_PATH=/opt/ai/oroma/data/state/gap_policy_mini_write_gate.json
OROMA_GAP_POLICY_MINI_WRITE_DBW_TIMEOUT_MS=15000
OROMA_GAP_POLICY_MINI_WRITE_DBW_PING_TIMEOUT_MS=500

# Gap Evidence Outcome Collector (read-only; keine Starts, keine Policy-Writes)
OROMA_ORCH_ENABLE_GAP_EVIDENCE_OUTCOME=0
OROMA_ORCH_INT_GAP_EVIDENCE_OUTCOME=1800
OROMA_ORCH_TIMEOUT_GAP_EVIDENCE_OUTCOME=20
OROMA_ORCH_GAP_EVIDENCE_OUTCOME_LIMIT=50
OROMA_ORCH_GAP_EVIDENCE_OUTCOME_TOPK=10
OROMA_ORCH_GAP_EVIDENCE_OUTCOME_LOOKBACK_SEC=1209600
OROMA_GAP_EVIDENCE_OUTCOME_BUCKETS=promotion_candidate_replay,promotion_candidate_dream
OROMA_GAP_EVIDENCE_OUTCOME_LIMIT=50
OROMA_GAP_EVIDENCE_OUTCOME_TOPK=10
OROMA_GAP_EVIDENCE_OUTCOME_REWARD_EPS=0.000001
OROMA_GAP_EVIDENCE_OUTCOME_LOOKBACK_SEC=1209600
OROMA_GAP_EVIDENCE_OUTCOME_STATE_PATH=/opt/ai/oroma/data/state/gap_evidence_outcomes.json

# Gap Targeted Evidence Probe (read-only, bounded, no starts/no policy write)
OROMA_ORCH_ENABLE_GAP_TARGETED_EVIDENCE_PROBE=0
OROMA_ORCH_INT_GAP_TARGETED_EVIDENCE_PROBE=1800
OROMA_ORCH_TIMEOUT_GAP_TARGETED_EVIDENCE_PROBE=30
OROMA_ORCH_GAP_TARGETED_EVIDENCE_PROBE_LIMIT=3
OROMA_ORCH_GAP_TARGETED_EVIDENCE_PROBE_TOPK=3
OROMA_ORCH_GAP_TARGETED_EVIDENCE_PROBE_SCAN_LIMIT=5000
OROMA_GAP_TARGETED_EVIDENCE_PROBE_BUCKETS=promotion_candidate_replay,promotion_candidate_dream
OROMA_GAP_TARGETED_EVIDENCE_PROBE_STATE_PATH=/opt/ai/oroma/data/state/gap_targeted_evidence_probe.json

# =============================================================================
# Gap Targeted Replay Evidence Probe · state-only · local headless adapter
# =============================================================================
OROMA_ORCH_ENABLE_GAP_REPLAY_EVIDENCE_PROBE=0
OROMA_ORCH_INT_GAP_REPLAY_EVIDENCE_PROBE=1800
OROMA_ORCH_TIMEOUT_GAP_REPLAY_EVIDENCE_PROBE=30
OROMA_ORCH_GAP_REPLAY_EVIDENCE_PROBE_LIMIT=3
OROMA_ORCH_GAP_REPLAY_EVIDENCE_PROBE_TOPK=3
OROMA_ORCH_GAP_REPLAY_EVIDENCE_PROBE_HORIZON_STEPS=80
OROMA_GAP_REPLAY_EVIDENCE_PROBE_BUCKETS=promotion_candidate_replay
OROMA_GAP_REPLAY_EVIDENCE_PROBE_LIMIT=3
OROMA_GAP_REPLAY_EVIDENCE_PROBE_TOPK=3
OROMA_GAP_REPLAY_EVIDENCE_PROBE_HORIZON_STEPS=80
OROMA_GAP_REPLAY_EVIDENCE_PROBE_NAMESPACE_ALLOWLIST=
OROMA_GAP_REPLAY_EVIDENCE_PROBE_STATE_SCHEMA_ALLOWLIST=
OROMA_GAP_REPLAY_EVIDENCE_PROBE_TARGET_ALLOWLIST=
OROMA_GAP_REPLAY_EVIDENCE_PROBE_SNAKE_SNAPCHAIN_SCAN_LIMIT=500
OROMA_GAP_REPLAY_EVIDENCE_PROBE_STATE_PATH=/opt/ai/oroma/data/state/gap_replay_evidence_probe.json

# =============================================================================
# Gap Evidence Outcome Queue Gate · DBWriter-only · no policy_rules write
# =============================================================================
OROMA_ORCH_ENABLE_GAP_EVIDENCE_OUTCOME_QUEUE=1
OROMA_ORCH_INT_GAP_EVIDENCE_OUTCOME_QUEUE=1800
OROMA_ORCH_TIMEOUT_GAP_EVIDENCE_OUTCOME_QUEUE=30
OROMA_ORCH_GAP_EVIDENCE_OUTCOME_QUEUE_LIMIT=10
OROMA_ORCH_GAP_EVIDENCE_OUTCOME_QUEUE_TOPK=10
OROMA_ORCH_GAP_EVIDENCE_OUTCOME_QUEUE_MIN_CONFIDENCE=0.50
OROMA_GAP_EVIDENCE_OUTCOME_QUEUE_WRITE_ENABLE=1
OROMA_GAP_EVIDENCE_OUTCOME_QUEUE_CONFIRM_REQUIRED=GAP_EVIDENCE_OUTCOME_QUEUE_REVIEWED
OROMA_GAP_EVIDENCE_OUTCOME_QUEUE_CONFIRM=GAP_EVIDENCE_OUTCOME_QUEUE_REVIEWED
OROMA_GAP_EVIDENCE_OUTCOME_QUEUE_MIN_CONFIDENCE=0.50
OROMA_GAP_EVIDENCE_OUTCOME_QUEUE_ALLOW_DRAW=0
OROMA_GAP_EVIDENCE_OUTCOME_QUEUE_LIMIT=10
OROMA_GAP_EVIDENCE_OUTCOME_QUEUE_TOPK=10
OROMA_GAP_EVIDENCE_OUTCOME_QUEUE_MAX_AGE_SEC=7200
OROMA_GAP_EVIDENCE_OUTCOME_QUEUE_ALLOW_STALE=0
OROMA_GAP_EVIDENCE_OUTCOME_QUEUE_SOURCE_PATH=/opt/ai/oroma/data/state/gap_replay_evidence_probe.json
OROMA_GAP_EVIDENCE_OUTCOME_QUEUE_STATE_PATH=/opt/ai/oroma/data/state/gap_evidence_outcome_queue_writer.json
OROMA_GAP_EVIDENCE_OUTCOME_QUEUE_DBW_TIMEOUT_MS=15000
OROMA_GAP_EVIDENCE_OUTCOME_QUEUE_DBW_PING_TIMEOUT_MS=500
