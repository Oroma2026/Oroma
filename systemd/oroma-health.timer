# =============================================================================
# Datei:    /etc/systemd/system/oroma-health.timer
# Projekt:  ORÓMA v3.8 – Healthcheck Timer
# Stand:    2025-11-30
# =============================================================================

[Unit]
Description=ORÓMA v3.8 – Healthcheck alle 5 Minuten

[Timer]
OnBootSec=110s
OnUnitActiveSec=5min
Unit=oroma-health.service
AccuracySec=30s
Persistent=true

RandomizedDelaySec=45s
[Install]
WantedBy=timers.target
