# =============================================================================
# Datei:    /etc/systemd/system/oroma-ptz-zoom-policy-preview.service
# Projekt:  ORÓMA (Offline-Realtime-Organic-Memory-AI)
# Modul:    PTZ Zoom Policy Preview – P3z1b Wide-Observe Dry-Run
# Version:  v3.7.3+p3z1b-wide-observe-policy-preview-systemd-v1.0
# Stand:    2026-06-25
# Autor:    ORÓMA · ChatGPT Patch-Gate
# Lizenz:   MIT
# =============================================================================
#
# ZWECK
# ─────
# Führt `tools/ptz_zoom_policy_preview.py` als read-only Oneshot aus. Das Tool
# berechnet, ob ORÓMA aktuell Zoom 100 als Such-/Orientierungszoom empfehlen
# würde, schreibt Preview-Metriken nach stats.db und steuert ausdrücklich keine
# Kamera.
#
# INVARIANTEN
# ───────────
# - Keine Zoom-/Pan-/Tilt-Steuerung.
# - Keine Policy-Aktivierung.
# - Keine Materialisierung in ObjectGraph/SnapGraph.
# - Keine Writes in oroma.db.
# - Stats ausschließlich via DBWriter nach stats.db.stats_points.
# - PTZ-Motor-State wird read-only aus data/state/ptz_motor_state.json gelesen.
#
# LOGS
# ────
#   /opt/ai/oroma/logs/ptz_zoom_policy_preview.out.log
#   /opt/ai/oroma/logs/ptz_zoom_policy_preview.err.log
#
# AKTIVIERUNG
# ───────────
#   sudo cp systemd/oroma-ptz-zoom-policy-preview.service /etc/systemd/system/
#   sudo cp systemd/oroma-ptz-zoom-policy-preview.timer /etc/systemd/system/
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now oroma-ptz-zoom-policy-preview.timer
#
# =============================================================================

[Unit]
Description=ORÓMA – PTZ Zoom Policy Preview (P3z1b dry-run)
Documentation=file:/opt/ai/oroma/docs/PTZ_MOTOR_WORKER.md
After=oroma-db-writer.service oroma.service oroma-ptz-motor-worker.service
Wants=oroma-db-writer.service
ConditionPathExists=/opt/ai/oroma/.use_orchestrator
ConditionPathExists=/opt/ai/oroma/tools/ptz_zoom_policy_preview.py

[Service]
Type=oneshot
User=oroma
Group=oroma
UMask=002
WorkingDirectory=/opt/ai/oroma
SyslogIdentifier=oroma-ptz-zoom-policy-preview
TimeoutStartSec=60

EnvironmentFile=-/opt/ai/oroma/.env.systemd
EnvironmentFile=-/opt/ai/oroma/.env
Environment=PYTHONUNBUFFERED=1
Environment=PYTHONIOENCODING=UTF-8
Environment=TZ=Europe/Berlin
Environment=PYTHONPATH=/opt/ai/oroma
Environment=OROMA_BASE=/opt/ai/oroma
Environment=PATH=/usr/local/bin:/usr/bin:/bin
Environment=OROMA_LOG_DIR=/opt/ai/oroma/logs
Environment=OROMA_DBW_ENABLE=1
Environment=OROMA_DBW_SOCKET=/opt/ai/oroma/data/state/db_writer.sock
Environment=OROMA_PTZ_ZOOM_POLICY_TARGET_ZOOM=100
Environment=OROMA_PTZ_ZOOM_POLICY_WINDOWS_MIN=60,360,1440
Environment=OROMA_PTZ_ZOOM_POLICY_MIN_HELPFUL_RATE=0.50
Environment=OROMA_PTZ_ZOOM_POLICY_MIN_CONTEXT_GAIN_RATE=0.35
Environment=OROMA_PTZ_ZOOM_POLICY_MIN_SAMPLE_COUNT=3
Environment=OROMA_PTZ_ZOOM_POLICY_TARGET_CONF_MAX=0.060
Environment=OROMA_PTZ_ZOOM_POLICY_OBS_CONF_MAX=0.080
Environment=OROMA_PTZ_ZOOM_POLICY_CANDIDATE_CONF_MAX=0.080
Environment=OROMA_PTZ_ZOOM_POLICY_ELIGIBLE_REASONS=deadzone,stale_frame,no_frame,energy_low
Environment=OROMA_PTZ_ZOOM_POLICY_DBW_TIMEOUT_MS=10000

ExecStartPre=+/usr/bin/env bash -lc 'mkdir -p /opt/ai/oroma/logs /opt/ai/oroma/data/state && touch /opt/ai/oroma/logs/ptz_zoom_policy_preview.out.log /opt/ai/oroma/logs/ptz_zoom_policy_preview.err.log && chown oroma:oroma /opt/ai/oroma/logs/ptz_zoom_policy_preview.out.log /opt/ai/oroma/logs/ptz_zoom_policy_preview.err.log && chown oroma:oroma /opt/ai/oroma/data/state'
ExecStart=/usr/bin/python3 /opt/ai/oroma/tools/ptz_zoom_policy_preview.py --once --write-stats --verbose

StandardOutput=append:/opt/ai/oroma/logs/ptz_zoom_policy_preview.out.log
StandardError=append:/opt/ai/oroma/logs/ptz_zoom_policy_preview.err.log

Nice=10
IOSchedulingClass=best-effort
IOSchedulingPriority=6

NoNewPrivileges=yes
PrivateTmp=yes
ProtectSystem=full
ProtectHome=yes
ProtectKernelModules=yes
ProtectKernelTunables=yes
ProtectKernelLogs=yes
ProtectControlGroups=yes
RestrictSUIDSGID=yes
RestrictNamespaces=yes
RestrictRealtime=yes
LockPersonality=yes
ReadWritePaths=/opt/ai/oroma/logs /opt/ai/oroma/data

[Install]
WantedBy=multi-user.target
